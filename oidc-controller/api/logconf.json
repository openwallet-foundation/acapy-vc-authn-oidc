{
  "logger": {
    "version": 1,
    "disable_existing_loggers": false,
    "formatters": {
      "plain": {
        "format": "%(message)s"
      }
    },
    "handlers": {
      "out": {
        "formatter": "plain",
        "class": "logging.StreamHandler",
        "stream": "ext://sys.stdout"
      }
    },
    "loggers": {
      "siem.audit": {
        "level": "INFO",
        "handlers": ["out"],
        "propagate": false
      }
    }
  }
}
